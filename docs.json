              "concepts/idempotency"
            ]
          },
          {
            "group": "Code Examples",
            "pages": [
              "examples/signing"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/error-codes"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.third-party.yaml"
      }
    ]
  },
