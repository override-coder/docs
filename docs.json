{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Poly Trader OpenAPI",
  "theme": "luma",
  "colors": {
    "primary": "#ef7025",
    "light": "#eec9bc",
    "dark": "#4fa1ab"
  },
  "favicon": "/favicon.svg",
  "api": {
    "openapi": "openapi.third-party.yaml",
    "playground": {
      "display": "interactive"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "overview/introduction",
              "overview/quickstart"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/authentication",
              "concepts/idempotency"
            ]
          },
          {
            "group": "Code Examples",
            "pages": [
              "examples/signing"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/error-codes"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.third-party.yaml"
      }
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://test-eu.polycopy.fun"
    }
