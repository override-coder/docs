{
  "$schema": "https://mintlify.com/docs.json",
  "name": "PolyCop OpenAPI",
  "theme": "luma",
  "colors": {
    "primary": "#ef7025",
    "light": "#eec9bc",
    "dark": "#4fa1ab"
  },
  "favicon": "/favicon.svg",
  "api": {
    "openapi": "openapi.third-party.yaml",
    "playground": {
      "display": "interactive"
    }
