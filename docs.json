  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "overview/introduction",
              "overview/quickstart"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
