  "projectName": "Poly Trader OpenAPI",
  "projectDescription": "A third-party REST API for programmatic trading on Poly Trader, secured with API Key + HMAC-SHA256 signatures, supporting wallet management, order placement, positions, copy-trading, and AFK strategies.",
